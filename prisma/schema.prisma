generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id          String @id @default(cuid())
  name        String
  storeNumber String @unique
  timezone    String // IANA timezone e.g. "America/New_York", "America/Chicago"
  users       User[]
}

model User {
  id            String      @id @default(cuid())
  employeeId    String
  name          String
  phone         String?
  email         String?
  pin           String      // bcrypt hashed, 12 rounds
  mustChangePin Boolean     @default(false)
  role          Role
  storeId       String?
  store         Store?      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  punches       TimePunch[]

  @@unique([employeeId, storeId])
}

enum Role {
  SUPER_ADMIN
  MANAGER
  EMPLOYEE
}

model TimePunch {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clockIn   DateTime
  clockOut  DateTime?
  createdAt DateTime  @default(now())
}
