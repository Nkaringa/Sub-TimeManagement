generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
}

model Store {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isOpen    Boolean  @default(true)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  users     User[]
  punches   TimePunch[]
}

model User {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])

  employeeId  String
  fullName    String   @default("")
  pinHash     String
  role        Role     @default(EMPLOYEE)

  phone       String?
  email       String?
  ssnLast4    String?

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  punches     TimePunch[]

  @@unique([storeId, employeeId])
}

model TimePunch {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  type      String
  at        DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([userId, at])
  @@index([storeId, at])
}

model SuperAdmin {
  id        String   @id @default(cuid())
  adminId   String   @unique
  pinHash   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model PaymentLog {
  id            String   @id @default(cuid())
  storeId       String
  userId        String
  employeeId    String
  employeeName  String
  periodStart   DateTime
  periodEnd     DateTime
  hoursWorked   Float
  hourlyRate    Float
  totalPaid     Float
  paidAt        DateTime @default(now())
  paidByManager String

  @@index([storeId, paidAt])
  @@index([userId, paidAt])
}